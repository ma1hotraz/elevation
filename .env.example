# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Server-only. Use the Supabase secret key or legacy service_role key.
# Never prefix this variable with NEXT_PUBLIC_ and never commit .env.local.
SUPABASE_SECRET_KEY=YOUR_SECRET_OR_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Application URL (required in production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Public institute details (recommended before launch)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=
NEXT_PUBLIC_CONTACT_PHONE_E164=
NEXT_PUBLIC_CONTACT_LOCATION=Canada
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_LINKEDIN_URL=


# -----------------------------------------------------------------------------
# Public enquiry protection (required in production)
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENQUIRY_HASH_SALT=replace-with-a-long-random-value

# -----------------------------------------------------------------------------
# One-time first-admin bootstrap (used only by npm run bootstrap:admin)
# Remove these from the hosting environment after the admin is created.
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_NAME=Institute Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

